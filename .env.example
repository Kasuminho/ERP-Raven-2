# App
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/guild_platform?schema=public&connection_limit=5&pool_timeout=10

# JWT
JWT_ACCESS_SECRET=replace_with_strong_access_secret
JWT_REFRESH_SECRET=replace_with_strong_refresh_secret
JWT_ACCESS_TTL=12h
JWT_REFRESH_TTL=7d

# Discord OAuth2
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_CALLBACK_URL=http://localhost:3000/api/v1/auth/discord/callback
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_GUILD_ID=your_discord_guild_id
DISCORD_AUCTIONS_CHANNEL_ID=your_auction_channel_id
DISCORD_ATTENDANCE_CHANNEL_ID=your_attendance_channel_id
DISCORD_STAFF_REVIEW_CHANNEL_ID=your_staff_review_channel_id
DISCORD_ANNOUNCEMENTS_CHANNEL_ID=your_announcements_channel_id
DISCORD_STAFF_ROLE_ID=1431337988423549000
DISCORD_DKP_CHANNEL_ID=your_dkp_channel_id
DISCORD_EVENTS_WEBHOOK_URL=
DISCORD_ANNOUNCEMENTS_WEBHOOK_URL=
DISCORD_AUCTIONS_WEBHOOK_URL=
DISCORD_DROPS_WEBHOOK_URL=
DISCORD_ATTENDANCE_WEBHOOK_URL=
DISCORD_STAFF_REVIEW_WEBHOOK_URL=
DISCORD_DKP_WEBHOOK_URL=
DISCORD_INTERESTS_WEBHOOK_URL=
DISCORD_ITEM_REQUESTS_WEBHOOK_URL=
DISCORD_STAFF_REQUESTS_WEBHOOK_URL=
DISCORD_UPDATES_WEBHOOK_URL=
DISCORD_STAFF_UPDATES_WEBHOOK_URL=
PUBLIC_APP_URL=http://localhost:5173
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1
CLOUDFLARE_TUNNEL_TOKEN=

# Image storage
IMAGE_STORAGE_PROVIDER=local
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON=
GOOGLE_DRIVE_PUBLIC_PERMISSION=true

# CORS
CORS_ORIGIN=http://localhost:5173
