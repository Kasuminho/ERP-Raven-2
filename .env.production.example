# Runtime
NODE_ENV=production
PORT=3000
API_PREFIX=api/v1
HEALTHCHECK_INTERVAL_MS=300000

# Public URLs
PUBLIC_APP_URL=https://app.guild-g3x.com.br
NEXT_PUBLIC_API_URL=https://app.guild-g3x.com.br/api/v1
CORS_ORIGIN=https://app.guild-g3x.com.br
DISCORD_CALLBACK_URL=https://app.guild-g3x.com.br/api/v1/auth/discord/callback

# Container ports exposed only to localhost for OpenResty proxy
API_HOST_PORT=3000
WEB_HOST_PORT=5173

# Immutable image tag (normally a Git commit SHA). APP_VERSION is only used by local image builds;
# published GHCR images bake the commit SHA during CI.
DEPLOY_IMAGE_TAG=latest
APP_VERSION=latest

# Container guardrails; tune after observing real production usage.
API_MEMORY_LIMIT=1536m
API_CPU_LIMIT=2.0
WEB_MEMORY_LIMIT=1024m
WEB_CPU_LIMIT=1.5
POSTGRES_MEMORY_LIMIT=1536m
POSTGRES_CPU_LIMIT=2.0
WATCHTOWER_MEMORY_LIMIT=256m
WATCHTOWER_CPU_LIMIT=0.5

# Backup policy. Values and credentials stay outside Git.
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=7
# BACKUP_GPG_RECIPIENT=operations@example.com
# BACKUP_GPG_PASSPHRASE_FILE=/run/secrets/backup-passphrase
# BACKUP_OFFSITE_COMMAND=rclone copy "$1" remote:guild-backups

# PostgreSQL container
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace_with_a_long_random_password
POSTGRES_DB=guild_platform
DATABASE_CONNECTION_LIMIT=8

# Prisma/Nest reads DATABASE_URL from docker-compose.prod.yml
DATABASE_URL=postgresql://postgres:replace_with_a_long_random_password@postgres:5432/guild_platform?schema=public&connection_limit=8&pool_timeout=10

# JWT
JWT_ACCESS_SECRET=replace_with_strong_access_secret
JWT_REFRESH_SECRET=replace_with_strong_refresh_secret
JWT_ACCESS_TTL=12h
JWT_REFRESH_TTL=7d

# Discord OAuth2 / bot
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_STAFF_ROLE_ID=1431337988423549000
DISCORD_STAFF_REVIEW_CHANNEL_ID=

# Discord webhooks
DISCORD_EVENTS_WEBHOOK_URL=
DISCORD_ANNOUNCEMENTS_WEBHOOK_URL=
DISCORD_AUCTIONS_WEBHOOK_URL=
DISCORD_DROPS_WEBHOOK_URL=
DISCORD_ATTENDANCE_WEBHOOK_URL=
DISCORD_STAFF_REVIEW_WEBHOOK_URL=
DISCORD_DKP_WEBHOOK_URL=
DISCORD_INTERESTS_WEBHOOK_URL=
DISCORD_ITEM_REQUESTS_WEBHOOK_URL=
DISCORD_STAFF_REQUESTS_WEBHOOK_URL=
DISCORD_UPDATES_WEBHOOK_URL=
DISCORD_STAFF_UPDATES_WEBHOOK_URL=
DISCORD_WEBHOOK_USERNAME=Aristolfo, 570 anos de webhook
DISCORD_WEBHOOK_AVATAR_URL=https://app.guild-g3x.com.br/aristolfo-webhooks.png
DISCORD_DEFAULT_LOCALE=pt-BR

# Image storage
IMAGE_STORAGE_PROVIDER=google_drive
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON=
GOOGLE_DRIVE_PUBLIC_PERMISSION=true

# Optional only if you keep Cloudflare Tunnel instead of ICP/OpenResty DNS+SSL
CLOUDFLARE_TUNNEL_TOKEN=
