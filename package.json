{
  "name": "erp-raven-2",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run -w @guild/api build && npm run -w @guild/web build",
    "build:web": "npm run -w @guild/web build",
    "start:api:prod": "npm run -w @guild/database prisma:generate && npx prisma migrate deploy --schema packages/database/prisma/schema.prisma && node -r ts-node/register -r tsconfig-paths/register apps/api/src/main.ts",
    "start:web:prod": "npm run -w @guild/web build && npm run -w @guild/web start",
    "start:dev": "npm run -w @guild/api start:dev",
    "start:web": "npm run -w @guild/web dev",
    "lint": "npm run -w @guild/api lint",
    "test": "npm run -w @guild/api test",
    "test:ci": "npm run -w @guild/api test:ci",
    "audit:ci": "node scripts/audit-policy.js",
    "smoke:public": "node scripts/public-smoke-test.js",
    "test:smoke": "node scripts/smoke-test.js",
    "discord:update": "node scripts/send-discord-update.js",
    "discord:configure-webhooks": "node scripts/configure-discord-webhooks.js",
    "images:migrate-drive": "node scripts/migrate-drive-images-to-local.js",
    "prisma:generate": "npm run -w @guild/database prisma:generate",
    "prisma:migrate:dev": "npm run -w @guild/database prisma:migrate:dev"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "globals": "^16.5.0",
    "typescript-eslint": "^8.59.4"
  }
}
