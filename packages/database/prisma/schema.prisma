model EventReminderDelivery {
  id                String    @id @default(uuid())
  eventId           String
  playerId          String
  rsvpStatus        String?
  webNotifiedAt     DateTime?
  discordClaimedAt  DateTime?
  discordNotifiedAt DateTime?
  discordAttempts   Int       @default(0)
  lastDiscordError  String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  event             Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  player            Player    @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([eventId, playerId])
  @@index([playerId, createdAt])
  @@index([discordNotifiedAt, discordClaimedAt])
}

model EventReserveEntry {
  id                   String             @id @default(uuid())
  eventId              String
  playerId             String
  position             Int
  reason               String
  status               EventReserveStatus @default(RESERVE)
  promotionRequestedAt DateTime?
  respondedAt          DateTime?
  promotedAt           DateTime?
  playerResponseNote   String?
  createdById          String
  updatedById          String
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  event                Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  player               Player             @relation(fields: [playerId], references: [id], onDelete: Cascade)
  createdBy            User               @relation("EventReserveCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedBy            User               @relation("EventReserveUpdatedBy", fields: [updatedById], references: [id], onDelete: Restrict)

  @@unique([eventId, playerId])
  @@index([eventId, status, position])
  @@index([playerId, status])
  @@index([createdById])
  @@index([updatedById])
}

model PlayerAbsence {
  id               String                        @id @default(uuid())
  playerId         String
  startsAt         DateTime
  endsAt           DateTime
  reason           String?
  reasonVisibility PlayerAbsenceReasonVisibility @default(STAFF_ONLY)
  createdAt        DateTime                      @default(now())
  updatedAt        DateTime                      @updatedAt
  player           Player                        @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId, startsAt, endsAt])
  @@index([startsAt, endsAt])
}

model DKPTransaction {
  id                 String                 @id @default(uuid())
  playerId           String
  amount             Int
  type               DKPTransactionType
  referenceId        String?
  createdById        String
  createdAt          DateTime               @default(now())
  player             Player                 @relation(fields: [playerId], references: [id], onDelete: Cascade)
  createdBy          User                   @relation("DKPTransactionCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  discordLogDelivery DiscordDkpLogDelivery?

  @@unique([playerId, type, referenceId])
  @@index([playerId, createdAt])
  @@index([type])
  @@index([referenceId])
  @@index([createdById])
}

model DiscordDkpLogState {
  id                  String    @id
  startedAt           DateTime
  backfillCompletedAt DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model DiscordDkpLogDelivery {
  id            String         @id @default(uuid())
  transactionId String         @unique
  sentAt        DateTime       @default(now())
  transaction   DKPTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([sentAt])
}

model DiscordWebhookDelivery {
  id             String                       @id @default(uuid())
  webhookKey     String
  channelLabel   String
  action         String?
  targetId       String?
  status         DiscordWebhookDeliveryStatus @default(PENDING)
  attempts       Int                          @default(0)
  maxAttempts    Int                          @default(5)
  retryable      Boolean                      @default(true)
  payloadPreview Json
  lastError      String?
  queuedAt       DateTime                     @default(now())
  startedAt      DateTime?
  sentAt         DateTime?
  failedAt       DateTime?
  retriedAt      DateTime?
  createdAt      DateTime                     @default(now())
  updatedAt      DateTime                     @updatedAt

  @@index([status, queuedAt])
  @@index([webhookKey, queuedAt])
  @@index([action])
  @@index([targetId])
}

model DKPLock {
  id        String   @id @default(uuid())
  playerId  String
  auctionId String
  amount    Int
  released  Boolean  @default(false)
  createdAt DateTime @default(now())
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  auction   Auction  @relation(fields: [auctionId], references: [id], onDelete: Cascade)

  @@unique([playerId, auctionId])
  @@index([auctionId])
  @@index([released])
}

model DkpPolicySimulation {
  id              String                    @id @default(uuid())
  type            DkpPolicySimulationType
  status          DkpPolicySimulationStatus @default(DRAFT)
  name            String
  config          Json
  result          Json
  createdById     String
  promotedById    String?
  promotedAt      DateTime?
  promotionReason String?
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt
  createdBy       User                      @relation("DkpPolicySimulationCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  promotedBy      User?                     @relation("DkpPolicySimulationPromotedBy", fields: [promotedById], references: [id], onDelete: SetNull)

  @@index([type, status, createdAt])
  @@index([createdById])
  @@index([promotedById])
}

model Auction {
  id                      String                          @id @default(uuid())
  itemCatalogId           String?
  itemName                String
  itemType                ItemType
  itemTier                ItemTier
  minimumBid              Int
  auctionMode             AuctionMode
  status                  AuctionStatus                   @default(OPEN)
  requiresStaffReview     Boolean                         @default(false)
  minimumLayer            Int?                            @db.SmallInt
  endsAt                  DateTime
  reopensAt               DateTime?
  createdById             String
  createdAt               DateTime                        @default(now())
  updatedAt               DateTime                        @updatedAt
  itemCatalog             ItemCatalog?                    @relation(fields: [itemCatalogId], references: [id], onDelete: SetNull)
  createdBy               User                            @relation("AuctionCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  bids                    AuctionBid[]
  dkpLocks                DKPLock[]
  reviewVotes             AuctionReviewVote[]
  bidInvalidationVotes    AuctionBidInvalidationVote[]
  bidCancellationRequests AuctionBidCancellationRequest[]
  disputes                AuctionDispute[]
  dropHistory             DropHistory?

  @@index([itemCatalogId])
  @@index([itemType])
  @@index([itemTier])
  @@index([auctionMode])
  @@index([status])
  @@index([minimumLayer])
  @@index([endsAt])
  @@index([reopensAt])
  @@index([createdById])
}

model AuctionBid {
  id                   String                          @id @default(uuid())
  auctionId            String
  playerId             String
  bidAmount            Int
  isValid              Boolean                         @default(true)
  createdAt            DateTime                        @default(now())
  auction              Auction                         @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  player               Player                          @relation(fields: [playerId], references: [id], onDelete: Cascade)
  cancellationRequests AuctionBidCancellationRequest[]
  invalidationVotes    AuctionBidInvalidationVote[]

  @@unique([auctionId, playerId])
  @@index([auctionId, createdAt])
  @@index([playerId])
  @@index([isValid])
}

model AuctionReviewVote {
  id        String   @id @default(uuid())
  auctionId String
  voterId   String
  action    String
  playerId  String?
  reason    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  auction   Auction  @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  voter     User     @relation("AuctionReviewVoteVoter", fields: [voterId], references: [id], onDelete: Cascade)

  @@unique([auctionId, voterId])
  @@index([auctionId, action])
  @@index([playerId])
  @@index([voterId])
}

model AuctionBidInvalidationVote {
  id        String     @id @default(uuid())
  auctionId String
  bidId     String
  voterId   String
  reason    String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  auction   Auction    @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  bid       AuctionBid @relation(fields: [bidId], references: [id], onDelete: Cascade)
  voter     User       @relation("AuctionBidInvalidationVoteVoter", fields: [voterId], references: [id], onDelete: Cascade)

  @@unique([bidId, voterId])
  @@index([auctionId, bidId])
  @@index([voterId])
}

model AuctionBidCancellationRequest {
  id           String                       @id @default(uuid())
  auctionId    String
  bidId        String
  playerId     String
  reason       String
  status       AuctionBidCancellationStatus @default(PENDING)
  reviewedById String?
  reviewNote   String?
  reviewedAt   DateTime?
  createdAt    DateTime                     @default(now())
  updatedAt    DateTime                     @updatedAt
  auction      Auction                      @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  bid          AuctionBid                   @relation(fields: [bidId], references: [id], onDelete: Cascade)
  player       Player                       @relation(fields: [playerId], references: [id], onDelete: Cascade)
  reviewedBy   User?                        @relation("AuctionBidCancellationReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([auctionId])
  @@index([bidId])
  @@index([playerId, createdAt])
  @@index([status, createdAt])
  @@index([reviewedById])
}

model AuctionDispute {
  id             String               @id @default(uuid())
  auctionId      String
  playerId       String
  reason         String
  proofImageUrl  String?
  status         AuctionDisputeStatus @default(PENDING)
  reviewedById   String?
  reviewedAt     DateTime?
  reviewNote     String?
  externalNotePt String?
  externalNoteEn String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  auction        Auction              @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  player         Player               @relation(fields: [playerId], references: [id], onDelete: Cascade)
  reviewedBy     User?                @relation("AuctionDisputeReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@unique([auctionId, playerId])
  @@index([auctionId, status, createdAt])
  @@index([playerId, status, createdAt])
  @@index([reviewedById])
}

model EligibilityRule {
  id                  String   @id @default(uuid())
  itemTier            ItemTier
  itemType            ItemType
  minimumLayer        Int      @db.SmallInt
  minimumDKP          Int
  requiresStaffReview Boolean  @default(false)

  @@unique([itemTier, itemType, minimumLayer])
  @@index([itemType])
  @@index([requiresStaffReview])
}

model ItemCatalog {
  id                 String               @id @default(uuid())
  legacyId           Int?                 @unique
  kind               String
  category           String
  itemTier           ItemTier?
  itemType           ItemType?
  namePt             String
  nameEn             String
  nameEs             String?
  typePt             String
  typeEn             String
  typeEs             String?
  preferredClasses   PlayerClass[]        @default([])
  image1Url          String?
  image2Url          String?
  isActive           Boolean              @default(true)
  diamondSaleEnabled Boolean              @default(false)
  legacyCreatedAt    DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  itemRequests       ItemRequest[]
  dropHistories      DropHistory[]
  auctions           Auction[]
  interestPosts      ItemInterestPost[]
  wishlistItems      PlayerWishlistItem[]
  diamondSales       DiamondSale[]

  @@index([nameEn, typeEn])
  @@index([nameEs, typeEs])
  @@index([kind])
  @@index([category])
  @@index([itemTier])
  @@index([itemType])
  @@index([isActive])
}

model ItemRequest {
  id                      String                   @id @default(uuid())
  legacyId                Int?                     @unique
  itemCatalogId           String?
  playerId                String?
  discordId               String
  playerName              String
  itemName                String
  imageUrl                String?
  totalQuantity           Int
  remainingQuantity       Int
  rankPosition            Int
  threadId                String?
  threadChannelId         String?
  warned3d                Boolean                  @default(false)
  warned4d                Boolean                  @default(false)
  updateProofImageUrl     String?
  updateProofNote         String?
  updateProofStatus       ItemRequestUpdateStatus?
  updateProofSubmittedAt  DateTime?
  updateProofReviewedAt   DateTime?
  updateProofReviewedById String?
  lastReminderStage       String?
  lastReminderAt          DateTime?
  legacyCreatedAt         DateTime?
  legacyUpdatedAt         DateTime?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  itemCatalog             ItemCatalog?             @relation(fields: [itemCatalogId], references: [id], onDelete: SetNull)
  player                  Player?                  @relation(fields: [playerId], references: [id], onDelete: SetNull)

  @@index([itemCatalogId])
  @@index([playerId])
  @@index([discordId])
  @@index([itemName])
  @@index([rankPosition])
  @@index([threadId])
  @@index([lastReminderStage])
  @@index([updateProofStatus])
  @@index([updateProofSubmittedAt])
}

model DropHistory {
  id                  String             @id @default(uuid())
  legacyId            Int?               @unique
  itemCatalogId       String?
  auctionId           String?            @unique
  itemInterestEntryId String?            @unique
  playerId            String?
  discordId           String?
  nicknameIngame      String?
  itemName            String?
  threadId            String?
  staffDiscordId      String?
  proofImageUrl       String?
  deliveredAt         DateTime?
  createdAt           DateTime           @default(now())
  itemCatalog         ItemCatalog?       @relation(fields: [itemCatalogId], references: [id], onDelete: SetNull)
  auction             Auction?           @relation(fields: [auctionId], references: [id], onDelete: SetNull)
  itemInterestEntry   ItemInterestEntry? @relation(fields: [itemInterestEntryId], references: [id], onDelete: SetNull)
  player              Player?            @relation(fields: [playerId], references: [id], onDelete: SetNull)

  @@index([itemCatalogId])
  @@index([playerId])
  @@index([itemInterestEntryId])
  @@index([discordId])
  @@index([itemName])
  @@index([threadId])
  @@index([deliveredAt])
}

model ItemInterestPost {
  id                      String              @id @default(uuid())
  itemCatalogId           String
  mode                    String              @default("PvE")
  title                   String
  criteriaPt              String
  criteriaEn              String
  status                  ItemInterestStatus  @default(OPEN)
  votingRound             Int                 @default(1)
  votingCandidateEntryIds Json                @default("[]")
  selectedEntryId         String?
  deliveryEnabledAt       DateTime?
  closesAt                DateTime
  closedAt                DateTime?
  proofImageUrl           String?
  createdById             String
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt
  itemCatalog             ItemCatalog         @relation(fields: [itemCatalogId], references: [id], onDelete: Cascade)
  createdBy               User                @relation("ItemInterestPostCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  entries                 ItemInterestEntry[]
  votes                   ItemInterestVote[]
  views                   ItemInterestView[]

  @@index([itemCatalogId])
  @@index([status])
  @@index([selectedEntryId])
  @@index([closesAt])
  @@index([createdById])
}

model ItemInterestView {
  id        String           @id @default(uuid())
  postId    String
  playerId  String
  seenAt    DateTime         @default(now())
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  post      ItemInterestPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  player    Player           @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([postId, playerId])
  @@index([playerId, seenAt])
  @@index([postId])
}

model ItemInterestEntry {
  id                 String             @id @default(uuid())
  postId             String
  playerId           String
  note               String?
  imageUrl           String?
  isTransmuteRequest Boolean            @default(false)
  createdAt          DateTime           @default(now())
  post               ItemInterestPost   @relation(fields: [postId], references: [id], onDelete: Cascade)
  player             Player             @relation(fields: [playerId], references: [id], onDelete: Cascade)
  dropHistory        DropHistory?
  votes              ItemInterestVote[]

  @@unique([postId, playerId])
  @@index([playerId])
  @@index([isTransmuteRequest])
  @@index([playerId, isTransmuteRequest])
}

model DiamondSale {
  id                 String                   @id @default(uuid())
  itemCatalogId      String
  itemName           String
  buyerType          DiamondSaleBuyerType
  buyerPlayerId      String?
  buyerName          String
  diamondCustodian   String
  diamondTotal       Int
  itemProofImageUrl  String
  saleProofImageUrl  String
  recipientMode      DiamondSaleRecipientMode
  shareAmount        Int
  remainderAmount    Int
  activePlayerCount  Int
  recipientCount     Int
  status             DiamondSaleStatus        @default(OPEN)
  openedAt           DateTime                 @default(now())
  completedAt        DateTime?
  discordPublishedAt DateTime?
  createdById        String
  completedById      String?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  itemCatalog        ItemCatalog              @relation(fields: [itemCatalogId], references: [id], onDelete: Restrict)
  buyerPlayer        Player?                  @relation("DiamondSaleBuyerPlayer", fields: [buyerPlayerId], references: [id], onDelete: Restrict)
  createdBy          User                     @relation("DiamondSaleCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  completedBy        User?                    @relation("DiamondSaleCompletedBy", fields: [completedById], references: [id], onDelete: SetNull)
  recipients         DiamondSaleRecipient[]

  @@index([itemCatalogId, openedAt])
  @@index([buyerPlayerId])
  @@index([status, openedAt])
  @@index([createdById])
}

model DiamondSaleRecipient {
  id             String      @id @default(uuid())
  saleId         String
  playerId       String
  playerNickname String
  diamondAmount  Int
  proofImageUrl  String?
  deliveredAt    DateTime?
  deliveredById  String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  sale           DiamondSale @relation(fields: [saleId], references: [id], onDelete: Cascade)
  player         Player      @relation(fields: [playerId], references: [id], onDelete: Restrict)
  deliveredBy    User?       @relation("DiamondSaleRecipientDeliveredBy", fields: [deliveredById], references: [id], onDelete: SetNull)

  @@unique([saleId, playerId])
  @@index([playerId, deliveredAt])
  @@index([saleId, deliveredAt])
  @@index([deliveredById])
}

model PlayerWishlistItem {
  id            String           @id @default(uuid())
  playerId      String
  itemCatalogId String
  priority      WishlistPriority @default(MEDIUM)
  status        WishlistStatus   @default(ACTIVE)
  reason        String
  build         String?
  note          String?
  proofImageUrl String?
  fulfilledById String?
  fulfilledAt   DateTime?
  fulfilledNote String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  player        Player           @relation(fields: [playerId], references: [id], onDelete: Cascade)
  itemCatalog   ItemCatalog      @relation(fields: [itemCatalogId], references: [id], onDelete: Cascade)

  @@index([playerId, status, priority])
  @@index([itemCatalogId, status, priority])
  @@index([status, updatedAt])
  @@index([fulfilledById])
}

model ItemInterestVote {
  id        String            @id @default(uuid())
  postId    String
  entryId   String
  voterId   String
  round     Int               @default(1)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  post      ItemInterestPost  @relation(fields: [postId], references: [id], onDelete: Cascade)
  entry     ItemInterestEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  voter     User              @relation("ItemInterestVoteVoter", fields: [voterId], references: [id], onDelete: Cascade)

  @@unique([postId, voterId, round])
  @@index([postId, round])
  @@index([entryId])
  @@index([voterId])
}

model CodexRequest {
  id               String             @id @default(uuid())
  playerId         String
  imageUrl         String
  note             String?
  status           CodexRequestStatus @default(PENDING)
  proofImageUrl    String?
  sentById         String?
  sentAt           DateTime?
  confirmedAt      DateTime?
  retryRequestedAt DateTime?
  queuedAt         DateTime           @default(now())
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  player           Player             @relation(fields: [playerId], references: [id], onDelete: Cascade)
  sentBy           User?              @relation("CodexRequestSentBy", fields: [sentById], references: [id], onDelete: SetNull)

  @@index([playerId])
  @@index([status])
  @@index([queuedAt])
  @@index([sentById])
  @@index([createdAt])
}

model DaoshiCashReceipt {
  id            String              @id @default(uuid())
  playerId      String
  proofImageUrl String?
  purchaseCents Int
  approvedCents Int?
  purchaseDate  DateTime
  couponCode    String              @default("AACD")
  status        DaoshiReceiptStatus @default(PENDING)
  playerNote    String?
  reviewNote    String?
  reviewedById  String?
  reviewedAt    DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  player        Player              @relation(fields: [playerId], references: [id], onDelete: Cascade)
  reviewedBy    User?               @relation("DaoshiReceiptReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([playerId, purchaseDate])
  @@index([status])
  @@index([purchaseDate])
  @@index([reviewedById])
}

model DaoshiRaffle {
  id             String   @id @default(uuid())
  month          String
  prizeUsdCents  Int      @default(5000)
  totalCents     Int
  totalCoupons   Int
  winnerPlayerId String?
  winnerCoupon   Int?
  entries        Json
  executedById   String
  executedAt     DateTime @default(now())
  createdAt      DateTime @default(now())
  winnerPlayer   Player?  @relation(fields: [winnerPlayerId], references: [id], onDelete: SetNull)
  executedBy     User     @relation("DaoshiRaffleExecutedBy", fields: [executedById], references: [id], onDelete: Restrict)

  @@unique([month])
  @@index([winnerPlayerId])
  @@index([executedById])
  @@index([executedAt])
}

model Announcement {
  id             String             @id @default(uuid())
  type           String
  title          String
  description    String?
  channelId      String
  mentionRoleId  String?
  eventTime      DateTime
  timezone       String             @default("America/Sao_Paulo")
  status         AnnouncementStatus @default(ACTIVE)
  warned4h       Boolean            @default(false)
  warned1h       Boolean            @default(false)
  warned30m      Boolean            @default(false)
  warnedNow      Boolean            @default(false)
  warnedDailyDay Int?
  createdById    String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  createdBy      User?              @relation("AnnouncementCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([eventTime])
  @@index([channelId])
  @@index([createdById])
}

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String?
  action     String
  targetType String
  targetId   String?
  metadata   Json?
  createdAt  DateTime @default(now())
  actor      User?    @relation("AuditLogActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([action])
  @@index([targetType, targetId])
  @@index([createdAt])
}

model ProductValidationInterview {
  id                          String                             @id @default(uuid())
  campaignKey                 String                             @default("G3X-2026-07")
  profile                     ProductValidationInterviewProfile
  channels                    String[]
  absenceVisibility           ProductValidationAbsenceVisibility
  rsvpWouldReduceManualCharge Boolean
  summary                     String
  interviewedAt               DateTime
  recordedById                String
  createdAt                   DateTime                           @default(now())
  updatedAt                   DateTime                           @updatedAt
  recordedBy                  User                               @relation("ProductValidationInterviewRecordedBy", fields: [recordedById], references: [id], onDelete: Restrict)

  @@index([campaignKey, profile])
  @@index([interviewedAt])
  @@index([recordedById])
}

model ProductValidationWeek {
  id                       String   @id @default(uuid())
  campaignKey              String   @default("G3X-2026-07")
  weekStart                DateTime
  weekEnd                  DateTime
  eventsCreated            Int
  expectedAttendance       Int?
  actualAttendance         Int
  noShows                  Int
  staffConfirmationMinutes Int
  recruitsConverted        Int
  recruitsWithActivity     Int
  singlePersonTasks        Int
  note                     String?
  capturedById             String
  capturedAt               DateTime @default(now())
  updatedAt                DateTime @updatedAt
  capturedBy               User     @relation("ProductValidationWeekCapturedBy", fields: [capturedById], references: [id], onDelete: Restrict)

  @@unique([campaignKey, weekStart])
  @@index([campaignKey, weekEnd])
  @@index([capturedById])
}
