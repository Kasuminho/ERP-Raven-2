}

enum DigestCadence {
  DAILY
  WEEKLY
  NONE
}

enum ProductValidationInterviewProfile {
  STAFF_LEADERSHIP
  STAFF_EVENTS
  STAFF_LOOT
  PLAYER_VETERAN
  PLAYER_NEW
  PLAYER_ACTIVE
  PLAYER_LOW_ACTIVITY
}

enum ProductValidationAbsenceVisibility {
  PUBLIC
  STAFF_ONLY
  ANONYMOUS
  DEPENDS_ON_REASON
}

model User {
  id                                  String                             @id @default(uuid())
  discordId                           String                             @unique
  discordUsername                     String
  avatar                              String?
  discordGuildId                      String?
  discordNickname                     String?
  discordRoles                        Json?
  preferredLocale                     String                             @default("pt")
  lastDiscordSyncAt                   DateTime?
  createdAt                           DateTime                           @default(now())
  updatedAt                           DateTime                           @updatedAt
  players                             Player[]
  createdEvents                       Event[]                            @relation("EventCreatedBy")
  createdEventSeries                  EventSeries[]                      @relation("EventSeriesCreatedBy")
  createdEventReserves                EventReserveEntry[]                @relation("EventReserveCreatedBy")
  updatedEventReserves                EventReserveEntry[]                @relation("EventReserveUpdatedBy")
  dkpTransactions                     DKPTransaction[]                   @relation("DKPTransactionCreatedBy")
  createdAuctions                     Auction[]                          @relation("AuctionCreatedBy")
  announcements                       Announcement[]                     @relation("AnnouncementCreatedBy")
  interestPosts                       ItemInterestPost[]                 @relation("ItemInterestPostCreatedBy")
  interestVotes                       ItemInterestVote[]                 @relation("ItemInterestVoteVoter")
  auctionReviewVotes                  AuctionReviewVote[]                @relation("AuctionReviewVoteVoter")
  auctionBidInvalidationVotes         AuctionBidInvalidationVote[]       @relation("AuctionBidInvalidationVoteVoter")
  reviewedBidCancellations            AuctionBidCancellationRequest[]    @relation("AuctionBidCancellationReviewedBy")
  reviewedAuctionDisputes             AuctionDispute[]                   @relation("AuctionDisputeReviewedBy")
  sentCodexRequests                   CodexRequest[]                     @relation("CodexRequestSentBy")
  reviewedProgress                    PlayerProgress[]                   @relation("PlayerProgressReviewedBy")
  progressComments                    PlayerProgressComment[]
  staffNotes                          PlayerStaffNote[]                  @relation("PlayerStaffNoteAuthor")
  updatedCombatProfiles               PlayerCombatProfile[]              @relation("PlayerCombatProfileUpdatedBy")
  reviewedCombatRequests              PlayerCombatProfileChangeRequest[] @relation("PlayerCombatRequestReviewedBy")
  createdWarRoomOperations            WarRoomOperation[]                 @relation("WarRoomOperationCreatedBy")
  createdWarRoomRosterSlots           WarRoomRosterSlot[]                @relation("WarRoomRosterSlotCreatedBy")
  markedWarRoomAttendanceSlots        WarRoomRosterSlot[]                @relation("WarRoomRosterSlotAttendanceMarkedBy")
  createdWarRoomTimelineEvents        WarRoomTimelineEvent[]             @relation("WarRoomTimelineEventCreatedBy")
  createdDkpPolicySimulations         DkpPolicySimulation[]              @relation("DkpPolicySimulationCreatedBy")
  promotedDkpPolicySimulations        DkpPolicySimulation[]              @relation("DkpPolicySimulationPromotedBy")
  reviewedDaoshiReceipts              DaoshiCashReceipt[]                @relation("DaoshiReceiptReviewedBy")
  executedDaoshiRaffles               DaoshiRaffle[]                     @relation("DaoshiRaffleExecutedBy")
  auditLogs                           AuditLog[]                         @relation("AuditLogActor")
  updatedBusinessRules                BusinessRule[]                     @relation("BusinessRuleUpdatedBy")
  notifications                       Notification[]
  reviewedRecruitmentApplications     RecruitmentApplication[]           @relation("RecruitmentApplicationReviewedBy")
  convertedRecruitmentApplications    RecruitmentApplication[]           @relation("RecruitmentApplicationConvertedBy")
  createdDiamondSales                 DiamondSale[]                      @relation("DiamondSaleCreatedBy")
  completedDiamondSales               DiamondSale[]                      @relation("DiamondSaleCompletedBy")
  deliveredDiamondShares              DiamondSaleRecipient[]             @relation("DiamondSaleRecipientDeliveredBy")
  createdGuildPolicies                GuildPolicyVersion[]               @relation("GuildPolicyCreatedBy")
  publishedGuildPolicies              GuildPolicyVersion[]               @relation("GuildPolicyPublishedBy")
  assignedGuildCases                  GuildCase[]                        @relation("GuildCaseAssignedTo")
  guildCaseEntries                    GuildCaseEntry[]                   @relation("GuildCaseEntryActor")
  createdOnboardingTemplates          OnboardingTemplate[]               @relation("OnboardingTemplateCreatedBy")
  completedOnboardingSteps            PlayerOnboardingStep[]             @relation("OnboardingStepCompletedBy")
  createdPlayerTrials                 PlayerTrial[]                      @relation("PlayerTrialCreatedBy")
  decidedPlayerTrials                 PlayerTrial[]                      @relation("PlayerTrialDecidedBy")
  playerTrialCheckIns                 PlayerTrialCheckIn[]               @relation("PlayerTrialCheckInAuthor")
  assignedMentorships                 MentorshipAssignment[]             @relation("MentorshipAssignedBy")
  createdGuildPulseCycles             GuildPulseCycle[]                  @relation("GuildPulseCreatedBy")
  moderatedGuildPulseResponses        GuildPulseResponse[]               @relation("GuildPulseModeratedBy")
  leadershipCheckIns                  LeadershipCheckIn[]
  createdStaffTasks                   StaffTask[]                        @relation("StaffTaskCreatedBy")
  ownedStaffTasks                     StaffTask[]                        @relation("StaffTaskOwner")
  substituteStaffTasks                StaffTask[]                        @relation("StaffTaskSubstitute")
  staffTaskHandoffs                   StaffTaskHandoff[]                 @relation("StaffTaskHandoffAuthor")
  primaryStaffAreaCoverages           StaffAreaCoverage[]                @relation("StaffAreaCoveragePrimary")
  backupStaffAreaCoverages            StaffAreaCoverage[]                @relation("StaffAreaCoverageBackup")
  updatedStaffAreaCoverages           StaffAreaCoverage[]                @relation("StaffAreaCoverageUpdatedBy")
  staffAvailabilityPeriods            StaffAvailabilityPeriod[]
  createdStaffAutomationRules         StaffAutomationRule[]              @relation("StaffAutomationRuleCreatedBy")
  createdPlaybookVersions             GuildPlaybookVersion[]             @relation("GuildPlaybookVersionCreatedBy")
  assignedPlaybooks                   GuildPlaybookAssignment[]          @relation("GuildPlaybookAssignedBy")
  ownedPlaybookLessons                GuildPlaybookLesson[]              @relation("GuildPlaybookLessonOwner")
  createdPlaybookLessons              GuildPlaybookLesson[]              @relation("GuildPlaybookLessonCreatedBy")
  recordedProductValidationInterviews ProductValidationInterview[]       @relation("ProductValidationInterviewRecordedBy")
  capturedProductValidationWeeks      ProductValidationWeek[]            @relation("ProductValidationWeekCapturedBy")

  @@index([discordUsername])
  @@index([discordGuildId])
}

model Player {
  id                              String                             @id @default(uuid())
  userId                          String
  nickname                        String                             @unique
  class                           PlayerClass
  dimensionalLayer                Int                                @db.SmallInt
  combatPower                     Int                                @default(0)
  timezone                        String?
  attendancePercentage            Float                              @default(0)
  eventReminderChannel            EventReminderChannel               @default(WEB)
  isActive                        Boolean                            @default(true)
  deactivatedAt                   DateTime?
  deactivatedById                 String?
  deactivationReason              String?
  reactivationRequestedAt         DateTime?
  joinedAt                        DateTime                           @default(now())
  createdAt                       DateTime                           @default(now())
  updatedAt                       DateTime                           @updatedAt
  user                            User                               @relation(fields: [userId], references: [id], onDelete: Cascade)
  playbookInstructionReceipts     PlaybookInstructionReceipt[]
  communicationPreference         PlayerCommunicationPreference?
  digestDeliveries                PlayerDigestDelivery[]
  roles                           PlayerRole[]
  attendances                     EventAttendance[]
  eventRsvps                      EventRsvp[]
  absences                        PlayerAbsence[]
  eventReserves                   EventReserveEntry[]
  dkpTransactions                 DKPTransaction[]
  dkpLocks                        DKPLock[]
  auctionBids                     AuctionBid[]
  auctionDisputes                 AuctionDispute[]
  progressUpdates                 PlayerProgress[]
  staffNotes                      PlayerStaffNote[]
  combatProfile                   PlayerCombatProfile?
  combatProfileRequests           PlayerCombatProfileChangeRequest[]
  warRoomRosterSlots              WarRoomRosterSlot[]
  itemInterests                   ItemInterestEntry[]
  itemInterestViews               ItemInterestView[]
  codexRequests                   CodexRequest[]
  itemRequests                    ItemRequest[]
  wishlistItems                   PlayerWishlistItem[]
  daoshiCashReceipts              DaoshiCashReceipt[]
  wonDaoshiRaffles                DaoshiRaffle[]
  dropHistories                   DropHistory[]
  bidCancellationRequests         AuctionBidCancellationRequest[]
  notifications                   Notification[]
  reminderDeliveries              PlayerReminderDelivery[]
  eventReminderDeliveries         EventReminderDelivery[]
  guildPolicyReceipts             GuildPolicyReceipt[]
  guildCases                      GuildCase[]
  onboardingPlan                  PlayerOnboardingPlan?
  trials                          PlayerTrial[]
  mentorProfile                   MentorProfile?
  mentorshipsAsMentee             MentorshipAssignment[]             @relation("MentorshipMentee")
  mentorshipsAsMentor             MentorshipAssignment[]             @relation("MentorshipMentor")
  mentorshipHelpRequests          MentorshipHelpRequest[]            @relation("MentorshipHelpRequester")
  assignedMentorshipHelpRequests  MentorshipHelpRequest[]            @relation("MentorshipHelpMentor")
  guildPulseParticipations        GuildPulseParticipation[]
  convertedRecruitmentApplication RecruitmentApplication?            @relation("RecruitmentApplicationConvertedPlayer")
  purchasedDiamondSales           DiamondSale[]                      @relation("DiamondSaleBuyerPlayer")
  diamondSaleRecipients           DiamondSaleRecipient[]

  @@index([userId])
  @@index([class])
  @@index([dimensionalLayer])
  @@index([attendancePercentage])
  @@index([isActive])
  @@index([reactivationRequestedAt])
}

model RecruitmentApplication {
  id                String                       @id @default(uuid())
  nickname          String
  discordTag        String?
  playerClass       PlayerClass
  combatPower       Int
  dimensionalLayer  Int                          @db.SmallInt
  availability      String
  focus             String
  experience        String
  proofImageUrl     String?
  notes             String?
  rulesAccepted     Boolean
  status            RecruitmentApplicationStatus @default(PENDING)
  reviewedById      String?
  convertedById     String?
  convertedPlayerId String?                      @unique
  reviewedAt        DateTime?
  convertedAt       DateTime?
  reviewNote        String?
  createdAt         DateTime                     @default(now())
  updatedAt         DateTime                     @updatedAt
  reviewedBy        User?                        @relation("RecruitmentApplicationReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  convertedBy       User?                        @relation("RecruitmentApplicationConvertedBy", fields: [convertedById], references: [id], onDelete: SetNull)
  convertedPlayer   Player?                      @relation("RecruitmentApplicationConvertedPlayer", fields: [convertedPlayerId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([playerClass])
  @@index([dimensionalLayer])
  @@index([reviewedById])
  @@index([convertedById])
}

model PlayerCombatProfile {
  playerId       String                   @id
  primaryClass   PlayerClass
  secondaryClass PlayerClass?
  declaredBuild  String?
  preferredRole  PlayerCombatRole?
  acceptedRoles  PlayerCombatRole[]       @default([])
  availability   PlayerCombatAvailability @default(UNSET)
  publicNote     String?
  staffNote      String?
  updatedById    String?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  player         Player                   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  updatedBy      User?                    @relation("PlayerCombatProfileUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([primaryClass])
  @@index([secondaryClass])
  @@index([preferredRole])
  @@index([availability])
  @@index([updatedById])
}

model PlayerCombatProfileChangeRequest {
  id             String                          @id @default(uuid())
  playerId       String
  primaryClass   PlayerClass?
  secondaryClass PlayerClass?
  declaredBuild  String?
  preferredRole  PlayerCombatRole?
  acceptedRoles  PlayerCombatRole[]              @default([])
  availability   PlayerCombatAvailability?
  proofImageUrl  String?
  note           String?
  status         PlayerCombatProfileChangeStatus @default(PENDING)
  reviewedById   String?
  reviewedAt     DateTime?
  reviewNote     String?
  createdAt      DateTime                        @default(now())
  updatedAt      DateTime                        @updatedAt
  player         Player                          @relation(fields: [playerId], references: [id], onDelete: Cascade)
  reviewedBy     User?                           @relation("PlayerCombatRequestReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([playerId, status, createdAt])
  @@index([status, createdAt])
  @@index([reviewedById])
}

model BusinessRule {
  id          String   @id @default(uuid())
  key         String   @unique
  category    String
  label       String
  description String?
  value       Json
  isActive    Boolean  @default(true)
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  updatedBy   User?    @relation("BusinessRuleUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([category])
  @@index([isActive])
}

model GuildPolicyVersion {
  id              String               @id @default(uuid())
  version         Int?                 @unique
  status          GuildPolicyStatus    @default(DRAFT)
  titlePt         String
  titleEn         String
  summaryPt       String
  summaryEn       String
  effectiveAt     DateTime
  isEmergency     Boolean              @default(false)
  emergencyReason String?
  snapshot        Json
  diffPt          Json                 @default("[]")
  diffEn          Json                 @default("[]")
  createdById     String
  publishedById   String?
  publishedAt     DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  createdBy       User                 @relation("GuildPolicyCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  publishedBy     User?                @relation("GuildPolicyPublishedBy", fields: [publishedById], references: [id], onDelete: SetNull)
  receipts        GuildPolicyReceipt[]

  @@index([status, effectiveAt])
  @@index([createdById])
  @@index([publishedById])
}

model GuildPolicyReceipt {
  id             String             @id @default(uuid())
  policyId       String
  playerId       String
  openedAt       DateTime?
  acknowledgedAt DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  policy         GuildPolicyVersion @relation(fields: [policyId], references: [id], onDelete: Cascade)
  player         Player             @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([policyId, playerId])
  @@index([policyId, openedAt, acknowledgedAt])
  @@index([playerId, acknowledgedAt])
}

model GuildCase {
  id           String            @id @default(uuid())
  playerId     String
  category     GuildCaseCategory
  severity     GuildCaseSeverity @default(MEDIUM)
  status       GuildCaseStatus   @default(OPEN)
  subject      String
  description  String
  assignedToId String?
  dueAt        DateTime?
  resolvedAt   DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  player       Player            @relation(fields: [playerId], references: [id], onDelete: Cascade)
  assignedTo   User?             @relation("GuildCaseAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  entries      GuildCaseEntry[]

  @@index([playerId, status, createdAt])
  @@index([status, severity, dueAt])
  @@index([assignedToId, status])
}

model GuildCaseEntry {
  id         String                   @id @default(uuid())
  caseId     String
  actorId    String?
  kind       GuildCaseEntryKind
  visibility GuildCaseEntryVisibility
  bodyPt     String?
  bodyEn     String?
  metadata   Json?
  createdAt  DateTime                 @default(now())
  guildCase  GuildCase                @relation(fields: [caseId], references: [id], onDelete: Cascade)
  actor      User?                    @relation("GuildCaseEntryActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([caseId, createdAt])
  @@index([actorId, createdAt])
}

model OnboardingTemplate {
  id          String                   @id @default(uuid())
  name        String
  version     Int                      @unique
  dueDays     Int                      @default(30)
  isActive    Boolean                  @default(false)
  createdById String
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
  createdBy   User                     @relation("OnboardingTemplateCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  steps       OnboardingTemplateStep[]
  plans       PlayerOnboardingPlan[]

  @@index([isActive, version])
  @@index([createdById])
}

model OnboardingTemplateStep {
  id             String                   @id @default(uuid())
  templateId     String
  key            String
  titlePt        String
  titleEn        String
  descriptionPt  String
  descriptionEn  String
  href           String
  isRequired     Boolean                  @default(true)
  completionType OnboardingCompletionType @default(MANUAL)
  displayOrder   Int
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  template       OnboardingTemplate       @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, key])
  @@index([templateId, displayOrder])
}

model PlayerOnboardingPlan {
  id          String                 @id @default(uuid())
  playerId    String                 @unique
  templateId  String
  startedAt   DateTime               @default(now())
  dueAt       DateTime
  completedAt DateTime?
  staffNote   String?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  player      Player                 @relation(fields: [playerId], references: [id], onDelete: Cascade)
  template    OnboardingTemplate     @relation(fields: [templateId], references: [id], onDelete: Restrict)
  steps       PlayerOnboardingStep[]

  @@index([templateId, completedAt])
  @@index([dueAt, completedAt])
}

model PlayerOnboardingStep {
  id             String                   @id @default(uuid())
  planId         String
  key            String
  titlePt        String
  titleEn        String
  descriptionPt  String
  descriptionEn  String
  href           String
  isRequired     Boolean                  @default(true)
  completionType OnboardingCompletionType
  displayOrder   Int
  completedAt    DateTime?
  completedById  String?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  plan           PlayerOnboardingPlan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  completedBy    User?                    @relation("OnboardingStepCompletedBy", fields: [completedById], references: [id], onDelete: SetNull)

  @@unique([planId, key])
  @@index([planId, displayOrder])
  @@index([completedById])
}

model PlayerTrial {
  id               String                   @id @default(uuid())
  playerId         String
  objectivePt      String
  objectiveEn      String
  plannedStartAt   DateTime
  plannedEndAt     DateTime
  status           PlayerTrialStatus        @default(ACTIVE)
  decisionType     PlayerTrialDecisionType?
  decisionReasonPt String?
  decisionReasonEn String?
  decidedAt        DateTime?
  createdById      String
  decidedById      String?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  player           Player                   @relation(fields: [playerId], references: [id], onDelete: Cascade)
