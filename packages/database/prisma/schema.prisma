generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PlayerClass {
  GUNSLINGER
  BERSERKER
  DESTROYER
  DEATHBRINGER
  ASSASSIN
  DIVINE_CASTER
  NIGHT_RANGER
  VANGUARD
  ELEMENTALIST
  WARLORD
}

enum EventType {
  LUNOS
  RIGRETO
  GARDRON
  MELKAR
  VARGAS
  BELLAMONICA
  SION
  ISTERIA
  NIDROK
  MORGON
  GUILD_DUNGEON
  SATURDAY_EVENT
  ABYSS_1
  ABYSS_1_2
  FLOUD
  KRATERIUS
  T3_ROTATION
}

enum EventStatus {
  OPEN
  ATTENDANCE_REGISTRATION
  FINALIZED
  CANCELLED
}

enum EventOperationalCategory {
  BOSS
  ABYSS
  GUILD_RAID
  FARM
  TRAINING
  CLASH
  CUSTOM
}

enum AuctionStatus {
  OPEN
  PENDING_REVIEW
  FINISHED
  CANCELLED
  RELISTED
}

enum AuctionMode {
  STANDARD
  ALL_IN
  STAFF_REVIEW
}

enum ItemTier {
  T2
  T3
  T4
  LEGENDARY
}

enum ItemType {
  WEAPON
  ARMOR
  ACCESSORY
  CELESTIAL_STONE
}

enum DKPTransactionType {
  EVENT_REWARD
  AUCTION_LOCK
  AUCTION_REFUND
  AUCTION_WIN
  ADMIN_ADJUSTMENT
}

enum AnnouncementStatus {
  ACTIVE
  SENT
  CANCELLED
}

enum ItemInterestStatus {
  OPEN
  CLOSED
  VOTING
  READY_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum CodexRequestStatus {
  PENDING
  SENT
  CONFIRMED
  NEEDS_RETRY
  CANCELLED
}

enum ItemRequestUpdateStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DaoshiReceiptStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AuctionBidCancellationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AuctionDisputeStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum DiscordWebhookDeliveryStatus {
  PENDING
  SENDING
  SENT
  FAILED
  RETRYING
}

enum ProgressCategory {
  STELLAS_AMPLIFICATION
  EQUIPMENT
  RELICS
  STIGMA
  ITEM_COLLECTION
  SKILLS
  PARADISE_STONES
  STATUS
  DIMENSIONAL_RIFT
  RUNES
}

enum ProgressReviewStatus {
  NOT_REQUIRED
  PENDING
  APPROVED
  REJECTED
}

enum PlayerStaffNoteSeverity {
  INFO
  WARNING
  STRIKE
}

enum PlayerCombatRole {
  FRONTLINE
  BACKLINE
  SUPPORT
  CALLER
  SCOUT
  FLEX
  RESERVE
}

enum PlayerCombatAvailability {
  UNSET
  WEEKDAYS
  WEEKENDS
  DAILY
  FLEX
  LOW
}

enum PlayerCombatProfileChangeStatus {
  PENDING
  APPROVED
  REJECTED
}

enum WarRoomOperationType {
  CLASH
  ANCIENT_FORTRESS
  ABYSS
  GUILD_RAID
  CUSTOM
}

enum WarRoomOperationStatus {
  DRAFT
  SCHEDULED
  ACTIVE
  CLOSED
  CANCELLED
}

enum WarRoomOperationPriority {
  LOW
  MEDIUM
  HIGH
}

enum WarRoomRosterSlotStatus {
  PENDING
  CONFIRMED
  DECLINED
  PRESENT
  ABSENT
  JUSTIFIED_ABSENCE
}

enum WarRoomTimelineEventType {
  NOTE
  CALL
  ENGAGE
  WIPE
  OBJECTIVE_CAPTURED
  BOSS
  TARGET_SWAP
  SUBSTITUTION
  CONTRIBUTION
  RISK
  CLOSED
}

enum DkpPolicySimulationType {
  DECAY
  BID_POLICY
}

enum DkpPolicySimulationStatus {
  DRAFT
  PROMOTED
  ARCHIVED
}

enum WishlistPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum WishlistStatus {
  ACTIVE
  PAUSED
  FULFILLED
  REMOVED
}

enum RecruitmentApplicationStatus {
  PENDING
  TRIAGE
  ACCEPTED
  REJECTED
  CONVERTED
  ARCHIVED
}

enum NotificationAudience {
  PLAYER
  STAFF
}

model User {
  id                       String                          @id @default(uuid())
  discordId                String                          @unique
  discordUsername          String
  avatar                   String?
  discordGuildId           String?
  discordNickname          String?
  discordRoles             Json?
  preferredLocale          String                          @default("pt")
  lastDiscordSyncAt        DateTime?
  createdAt                DateTime                        @default(now())
  updatedAt                DateTime                        @updatedAt
  players                  Player[]
  createdEvents            Event[]                         @relation("EventCreatedBy")
  dkpTransactions          DKPTransaction[]                @relation("DKPTransactionCreatedBy")
  createdAuctions          Auction[]                       @relation("AuctionCreatedBy")
  announcements            Announcement[]                  @relation("AnnouncementCreatedBy")
  interestPosts            ItemInterestPost[]              @relation("ItemInterestPostCreatedBy")
  interestVotes            ItemInterestVote[]              @relation("ItemInterestVoteVoter")
  auctionReviewVotes       AuctionReviewVote[]             @relation("AuctionReviewVoteVoter")
  auctionBidInvalidationVotes AuctionBidInvalidationVote[]  @relation("AuctionBidInvalidationVoteVoter")
  reviewedBidCancellations AuctionBidCancellationRequest[] @relation("AuctionBidCancellationReviewedBy")
  reviewedAuctionDisputes  AuctionDispute[]                @relation("AuctionDisputeReviewedBy")
  sentCodexRequests        CodexRequest[]                  @relation("CodexRequestSentBy")
  reviewedProgress         PlayerProgress[]                @relation("PlayerProgressReviewedBy")
  progressComments         PlayerProgressComment[]
  staffNotes               PlayerStaffNote[]               @relation("PlayerStaffNoteAuthor")
  updatedCombatProfiles    PlayerCombatProfile[]           @relation("PlayerCombatProfileUpdatedBy")
  reviewedCombatRequests   PlayerCombatProfileChangeRequest[] @relation("PlayerCombatRequestReviewedBy")
  createdWarRoomOperations WarRoomOperation[]               @relation("WarRoomOperationCreatedBy")
  createdWarRoomRosterSlots WarRoomRosterSlot[]             @relation("WarRoomRosterSlotCreatedBy")
  markedWarRoomAttendanceSlots WarRoomRosterSlot[]          @relation("WarRoomRosterSlotAttendanceMarkedBy")
  createdWarRoomTimelineEvents WarRoomTimelineEvent[]       @relation("WarRoomTimelineEventCreatedBy")
  createdDkpPolicySimulations DkpPolicySimulation[]         @relation("DkpPolicySimulationCreatedBy")
  promotedDkpPolicySimulations DkpPolicySimulation[]        @relation("DkpPolicySimulationPromotedBy")
  reviewedDaoshiReceipts   DaoshiCashReceipt[]             @relation("DaoshiReceiptReviewedBy")
  executedDaoshiRaffles    DaoshiRaffle[]                  @relation("DaoshiRaffleExecutedBy")
  auditLogs                AuditLog[]                      @relation("AuditLogActor")
  updatedBusinessRules     BusinessRule[]                  @relation("BusinessRuleUpdatedBy")
  notifications            Notification[]
  reviewedRecruitmentApplications RecruitmentApplication[] @relation("RecruitmentApplicationReviewedBy")
  convertedRecruitmentApplications RecruitmentApplication[] @relation("RecruitmentApplicationConvertedBy")

  @@index([discordUsername])
  @@index([discordGuildId])
}

model Player {
  id                      String                          @id @default(uuid())
  userId                  String
  nickname                String                          @unique
  class                   PlayerClass
  dimensionalLayer        Int                             @db.SmallInt
  combatPower             Int                             @default(0)
  timezone                String?
  attendancePercentage    Float                           @default(0)
  isActive                Boolean                         @default(true)
  joinedAt                DateTime                        @default(now())
  createdAt               DateTime                        @default(now())
  updatedAt               DateTime                        @updatedAt
  user                    User                            @relation(fields: [userId], references: [id], onDelete: Cascade)
  roles                   PlayerRole[]
  attendances             EventAttendance[]
  dkpTransactions         DKPTransaction[]
  dkpLocks                DKPLock[]
  auctionBids             AuctionBid[]
  auctionDisputes         AuctionDispute[]
  progressUpdates         PlayerProgress[]
  staffNotes              PlayerStaffNote[]
  combatProfile           PlayerCombatProfile?
  combatProfileRequests   PlayerCombatProfileChangeRequest[]
  warRoomRosterSlots      WarRoomRosterSlot[]
  itemInterests           ItemInterestEntry[]
  itemInterestViews       ItemInterestView[]
  codexRequests           CodexRequest[]
  itemRequests            ItemRequest[]
  wishlistItems           PlayerWishlistItem[]
  daoshiCashReceipts      DaoshiCashReceipt[]
  wonDaoshiRaffles        DaoshiRaffle[]
  dropHistories           DropHistory[]
  bidCancellationRequests AuctionBidCancellationRequest[]
  notifications           Notification[]
  convertedRecruitmentApplication RecruitmentApplication? @relation("RecruitmentApplicationConvertedPlayer")

  @@index([userId])
  @@index([class])
  @@index([dimensionalLayer])
  @@index([attendancePercentage])
  @@index([isActive])
}

model RecruitmentApplication {
  id             String                       @id @default(uuid())
  nickname       String
  discordTag     String?
  playerClass    PlayerClass
  combatPower    Int
  dimensionalLayer Int                        @db.SmallInt
  availability   String
  focus          String
  experience     String
  proofImageUrl  String?
  notes          String?
  rulesAccepted  Boolean
  status         RecruitmentApplicationStatus @default(PENDING)
  reviewedById   String?
  convertedById  String?
  convertedPlayerId String?                   @unique
  reviewedAt     DateTime?
  convertedAt    DateTime?
  reviewNote     String?
  createdAt      DateTime                     @default(now())
  updatedAt      DateTime                     @updatedAt
  reviewedBy     User?                        @relation("RecruitmentApplicationReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  convertedBy    User?                        @relation("RecruitmentApplicationConvertedBy", fields: [convertedById], references: [id], onDelete: SetNull)
  convertedPlayer Player?                     @relation("RecruitmentApplicationConvertedPlayer", fields: [convertedPlayerId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([playerClass])
  @@index([dimensionalLayer])
  @@index([reviewedById])
  @@index([convertedById])
}

model PlayerCombatProfile {
  playerId        String                   @id
  primaryClass    PlayerClass
  secondaryClass  PlayerClass?
  declaredBuild   String?
  preferredRole   PlayerCombatRole?
  acceptedRoles   PlayerCombatRole[]       @default([])
  availability    PlayerCombatAvailability @default(UNSET)
  publicNote      String?
  staffNote       String?
  updatedById     String?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  player          Player                   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  updatedBy       User?                    @relation("PlayerCombatProfileUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([primaryClass])
  @@index([secondaryClass])
  @@index([preferredRole])
  @@index([availability])
  @@index([updatedById])
}

model PlayerCombatProfileChangeRequest {
  id              String                           @id @default(uuid())
  playerId        String
  primaryClass    PlayerClass?
  secondaryClass  PlayerClass?
  declaredBuild   String?
  preferredRole   PlayerCombatRole?
  acceptedRoles   PlayerCombatRole[]               @default([])
  availability    PlayerCombatAvailability?
  proofImageUrl   String?
  note            String?
  status          PlayerCombatProfileChangeStatus  @default(PENDING)
  reviewedById    String?
  reviewedAt      DateTime?
  reviewNote      String?
  createdAt       DateTime                         @default(now())
  updatedAt       DateTime                         @updatedAt
  player          Player                           @relation(fields: [playerId], references: [id], onDelete: Cascade)
  reviewedBy      User?                            @relation("PlayerCombatRequestReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([playerId, status, createdAt])
  @@index([status, createdAt])
  @@index([reviewedById])
}

model BusinessRule {
  id          String   @id @default(uuid())
  key         String   @unique
  category    String
  label       String
  description String?
  value       Json
  isActive    Boolean  @default(true)
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  updatedBy   User?    @relation("BusinessRuleUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([category])
  @@index([isActive])
}

model Notification {
  id        String               @id @default(uuid())
  userId    String?
  playerId  String?
  audience  NotificationAudience @default(PLAYER)
  type      String
  title     String
  body      String
  href      String?
  metadata  Json?
  readAt    DateTime?
  createdAt DateTime             @default(now())
  user      User?                @relation(fields: [userId], references: [id], onDelete: Cascade)
  player    Player?              @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
  @@index([playerId, readAt, createdAt])
  @@index([audience, readAt, createdAt])
  @@index([type])
}

model PlayerStaffNote {
  id        String                  @id @default(uuid())
  playerId  String
  authorId  String
  severity  PlayerStaffNoteSeverity @default(INFO)
  body      String
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt
  player    Player                  @relation(fields: [playerId], references: [id], onDelete: Cascade)
  author    User                    @relation("PlayerStaffNoteAuthor", fields: [authorId], references: [id], onDelete: Restrict)

  @@index([playerId, createdAt])
  @@index([authorId])
  @@index([severity])
}

model PlayerProgress {
  id                   String                  @id @default(uuid())
  playerId             String
  category             ProgressCategory        @default(STATUS)
  level                Int?
  note                 String?
  imageUrl             String?
  imageUrls            Json                    @default("[]")
  reviewStatus         ProgressReviewStatus    @default(NOT_REQUIRED)
  requiresStaffReview  Boolean                 @default(false)
  combatPower          Int?
  dimensionalLayer     Int?                    @db.SmallInt
  reviewedById         String?
  reviewedAt           DateTime?
  reviewNote           String?
  playerReadCommentsAt DateTime?
  createdAt            DateTime                @default(now())
  player               Player                  @relation(fields: [playerId], references: [id], onDelete: Cascade)
  reviewedBy           User?                   @relation("PlayerProgressReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  comments             PlayerProgressComment[]

  @@index([playerId, createdAt])
  @@index([category])
  @@index([reviewStatus])
  @@index([reviewedById])
}

model PlayerProgressComment {
  id         String         @id @default(uuid())
  progressId String
  authorId   String
  body       String
  createdAt  DateTime       @default(now())
  progress   PlayerProgress @relation(fields: [progressId], references: [id], onDelete: Cascade)
  author     User           @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([progressId, createdAt])
  @@index([authorId])
}

model GuildRole {
  id      String       @id @default(uuid())
  name    String       @unique
  players PlayerRole[]
}

model PlayerRole {
  playerId String
  roleId   String
  player   Player    @relation(fields: [playerId], references: [id], onDelete: Cascade)
  role     GuildRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([playerId, roleId])
  @@index([roleId])
}

model Event {
  id                String            @id @default(uuid())
  name              String
  type              EventType
  status            EventStatus       @default(OPEN)
  operationalCategory EventOperationalCategory @default(BOSS)
  priority          WarRoomOperationPriority @default(MEDIUM)
  dkpReward         Int
  startsAt          DateTime
  endsAt            DateTime?
  finalizedAt       DateTime?
  dkpDistributedAt  DateTime?
  createdById       String
  responsibleUserId String?
  attendanceBatchId String?
  batchOrder        Int?
  checklist         Json              @default("[]")
  operationalNotes  String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  createdBy         User              @relation("EventCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  attendances       EventAttendance[]
  warRoomOperations WarRoomOperation[]

  @@index([type])
  @@index([status])
  @@index([operationalCategory])
  @@index([priority])
  @@index([startsAt])
  @@index([endsAt])
  @@index([finalizedAt])
  @@index([createdById])
  @@index([responsibleUserId])
  @@index([attendanceBatchId, batchOrder])
}

model WarRoomOperation {
  id            String                   @id @default(uuid())
  name          String
  type          WarRoomOperationType
  status        WarRoomOperationStatus   @default(DRAFT)
  priority      WarRoomOperationPriority @default(MEDIUM)
  startsAt      DateTime
  endsAt        DateTime
  mapRegion     String?
  objective     String?
  staffNotes    String?
  result        String?
  score         String?
  improvementNotes String?
  internalLinks Json                     @default("[]")
  eventId       String?
  createdById   String
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt
  event         Event?                   @relation(fields: [eventId], references: [id], onDelete: SetNull)
  createdBy     User                     @relation("WarRoomOperationCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  rosterSlots   WarRoomRosterSlot[]
  timelineEvents WarRoomTimelineEvent[]

  @@index([type])
  @@index([status])
  @@index([priority])
  @@index([startsAt])
  @@index([endsAt])
  @@index([eventId])
  @@index([createdById])
}

model WarRoomRosterSlot {
  id                   String                  @id @default(uuid())
  operationId          String
  playerId             String
  role                 PlayerCombatRole
  status               WarRoomRosterSlotStatus @default(PENDING)
  requiredClass        PlayerClass?
  requiredLayer        Int?                    @db.SmallInt
  publicInstructionsPt String?
  publicInstructionsEn String?
  staffNote            String?
  playerNote           String?
  confirmedAt          DateTime?
  attendanceMarkedAt   DateTime?
  attendanceMarkedById String?
  createdById          String
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  operation            WarRoomOperation        @relation(fields: [operationId], references: [id], onDelete: Cascade)
  player               Player                  @relation(fields: [playerId], references: [id], onDelete: Cascade)
  createdBy            User                    @relation("WarRoomRosterSlotCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  attendanceMarkedBy   User?                   @relation("WarRoomRosterSlotAttendanceMarkedBy", fields: [attendanceMarkedById], references: [id], onDelete: SetNull)

  @@unique([operationId, playerId])
  @@index([operationId, status])
  @@index([playerId, status])
  @@index([role])
  @@index([requiredClass])
  @@index([attendanceMarkedById])
  @@index([createdById])
}

model WarRoomTimelineEvent {
  id          String                   @id @default(uuid())
  operationId String
  type        WarRoomTimelineEventType @default(NOTE)
  occurredAt  DateTime                 @default(now())
  title       String
  note        String?
  metadata    Json                     @default("{}")
  createdById String
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
  operation   WarRoomOperation         @relation(fields: [operationId], references: [id], onDelete: Cascade)
  createdBy   User                     @relation("WarRoomTimelineEventCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([operationId, occurredAt])
  @@index([type])
  @@index([createdById])
}

model EventAttendance {
  id        String   @id @default(uuid())
  eventId   String
  playerId  String
  attended  Boolean  @default(false)
  createdAt DateTime @default(now())
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([eventId, playerId])
  @@index([playerId])
  @@index([attended])
}

model DKPTransaction {
  id          String             @id @default(uuid())
  playerId    String
  amount      Int
  type        DKPTransactionType
  referenceId String?
  createdById String
  createdAt   DateTime           @default(now())
  player      Player             @relation(fields: [playerId], references: [id], onDelete: Cascade)
  createdBy   User               @relation("DKPTransactionCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  discordLogDelivery DiscordDkpLogDelivery?

  @@unique([playerId, type, referenceId])
  @@index([playerId, createdAt])
  @@index([type])
  @@index([referenceId])
  @@index([createdById])
}

model DiscordDkpLogState {
  id                  String    @id
  startedAt           DateTime
  backfillCompletedAt DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model DiscordDkpLogDelivery {
  id            String         @id @default(uuid())
  transactionId String         @unique
  sentAt        DateTime       @default(now())
  transaction   DKPTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([sentAt])
}

model DiscordWebhookDelivery {
  id             String                       @id @default(uuid())
  webhookKey     String
  channelLabel   String
  action         String?
  targetId       String?
  status         DiscordWebhookDeliveryStatus @default(PENDING)
  attempts       Int                          @default(0)
  maxAttempts    Int                          @default(5)
  retryable      Boolean                      @default(true)
  payloadPreview Json
  lastError      String?
  queuedAt       DateTime                     @default(now())
  startedAt      DateTime?
  sentAt         DateTime?
  failedAt       DateTime?
  retriedAt      DateTime?
  createdAt      DateTime                     @default(now())
  updatedAt      DateTime                     @updatedAt

  @@index([status, queuedAt])
  @@index([webhookKey, queuedAt])
  @@index([action])
  @@index([targetId])
}

model DKPLock {
  id        String   @id @default(uuid())
  playerId  String
  auctionId String
  amount    Int
  released  Boolean  @default(false)
  createdAt DateTime @default(now())
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  auction   Auction  @relation(fields: [auctionId], references: [id], onDelete: Cascade)

  @@unique([playerId, auctionId])
  @@index([auctionId])
  @@index([released])
}

model DkpPolicySimulation {
  id          String                    @id @default(uuid())
  type        DkpPolicySimulationType
  status      DkpPolicySimulationStatus @default(DRAFT)
  name        String
  config      Json
  result      Json
  createdById String
  promotedById String?
  promotedAt  DateTime?
  promotionReason String?
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt
  createdBy   User                      @relation("DkpPolicySimulationCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  promotedBy  User?                     @relation("DkpPolicySimulationPromotedBy", fields: [promotedById], references: [id], onDelete: SetNull)

  @@index([type, status, createdAt])
  @@index([createdById])
  @@index([promotedById])
}

model Auction {
  id                      String                          @id @default(uuid())
  itemCatalogId           String?
  itemName                String
  itemType                ItemType
  itemTier                ItemTier
  minimumBid              Int
  auctionMode             AuctionMode
  status                  AuctionStatus                   @default(OPEN)
  requiresStaffReview     Boolean                         @default(false)
  minimumLayer            Int?                            @db.SmallInt
  endsAt                  DateTime
  reopensAt               DateTime?
  createdById             String
  createdAt               DateTime                        @default(now())
  updatedAt               DateTime                        @updatedAt
  itemCatalog             ItemCatalog?                    @relation(fields: [itemCatalogId], references: [id], onDelete: SetNull)
  createdBy               User                            @relation("AuctionCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  bids                    AuctionBid[]
  dkpLocks                DKPLock[]
  reviewVotes             AuctionReviewVote[]
  bidInvalidationVotes     AuctionBidInvalidationVote[]
  bidCancellationRequests AuctionBidCancellationRequest[]
  disputes                AuctionDispute[]
  dropHistory             DropHistory?

  @@index([itemCatalogId])
  @@index([itemType])
  @@index([itemTier])
  @@index([auctionMode])
  @@index([status])
  @@index([minimumLayer])
  @@index([endsAt])
  @@index([reopensAt])
  @@index([createdById])
}

model AuctionBid {
  id                   String                          @id @default(uuid())
  auctionId            String
  playerId             String
  bidAmount            Int
  isValid              Boolean                         @default(true)
  createdAt            DateTime                        @default(now())
  auction              Auction                         @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  player               Player                          @relation(fields: [playerId], references: [id], onDelete: Cascade)
  cancellationRequests AuctionBidCancellationRequest[]
  invalidationVotes    AuctionBidInvalidationVote[]

  @@unique([auctionId, playerId])
  @@index([auctionId, createdAt])
  @@index([playerId])
  @@index([isValid])
}

model AuctionReviewVote {
  id        String   @id @default(uuid())
  auctionId String
  voterId   String
  action    String
  playerId  String?
  reason    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  auction   Auction  @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  voter     User     @relation("AuctionReviewVoteVoter", fields: [voterId], references: [id], onDelete: Cascade)

  @@unique([auctionId, voterId])
  @@index([auctionId, action])
  @@index([playerId])
  @@index([voterId])
}

model AuctionBidInvalidationVote {
  id        String     @id @default(uuid())
  auctionId String
  bidId     String
  voterId   String
  reason    String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  auction   Auction    @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  bid       AuctionBid @relation(fields: [bidId], references: [id], onDelete: Cascade)
  voter     User       @relation("AuctionBidInvalidationVoteVoter", fields: [voterId], references: [id], onDelete: Cascade)

  @@unique([bidId, voterId])
  @@index([auctionId, bidId])
  @@index([voterId])
}

model AuctionBidCancellationRequest {
  id           String                       @id @default(uuid())
  auctionId    String
  bidId        String
  playerId     String
  reason       String
  status       AuctionBidCancellationStatus @default(PENDING)
  reviewedById String?
  reviewNote   String?
  reviewedAt   DateTime?
  createdAt    DateTime                     @default(now())
  updatedAt    DateTime                     @updatedAt
  auction      Auction                      @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  bid          AuctionBid                   @relation(fields: [bidId], references: [id], onDelete: Cascade)
  player       Player                       @relation(fields: [playerId], references: [id], onDelete: Cascade)
  reviewedBy   User?                        @relation("AuctionBidCancellationReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([auctionId])
  @@index([bidId])
  @@index([playerId, createdAt])
  @@index([status, createdAt])
  @@index([reviewedById])
}

model AuctionDispute {
  id             String               @id @default(uuid())
  auctionId      String
  playerId       String
  reason         String
  proofImageUrl  String?
  status         AuctionDisputeStatus @default(PENDING)
  reviewedById   String?
  reviewedAt     DateTime?
  reviewNote     String?
  externalNotePt String?
  externalNoteEn String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  auction        Auction              @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  player         Player               @relation(fields: [playerId], references: [id], onDelete: Cascade)
  reviewedBy     User?                @relation("AuctionDisputeReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@unique([auctionId, playerId])
  @@index([auctionId, status, createdAt])
  @@index([playerId, status, createdAt])
  @@index([reviewedById])
}

model EligibilityRule {
  id                  String   @id @default(uuid())
  itemTier            ItemTier
  itemType            ItemType
  minimumLayer        Int      @db.SmallInt
  minimumDKP          Int
  requiresStaffReview Boolean  @default(false)

  @@unique([itemTier, itemType, minimumLayer])
  @@index([itemType])
  @@index([requiresStaffReview])
}

model ItemCatalog {
  id               String             @id @default(uuid())
  legacyId         Int?               @unique
  kind             String
  category         String
  itemTier         ItemTier?
  itemType         ItemType?
  namePt           String
  nameEn           String
  nameEs           String?
  typePt           String
  typeEn           String
  typeEs           String?
  preferredClasses PlayerClass[]      @default([])
  image1Url        String?
  image2Url        String?
  isActive         Boolean            @default(true)
  legacyCreatedAt  DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  itemRequests     ItemRequest[]
  dropHistories    DropHistory[]
  auctions         Auction[]
  interestPosts    ItemInterestPost[]
  wishlistItems    PlayerWishlistItem[]

  @@index([nameEn, typeEn])
  @@index([nameEs, typeEs])
  @@index([kind])
  @@index([category])
  @@index([itemTier])
  @@index([itemType])
  @@index([isActive])
}

model ItemRequest {
  id                      String                   @id @default(uuid())
  legacyId                Int?                     @unique
  itemCatalogId           String?
  playerId                String?
  discordId               String
  playerName              String
  itemName                String
  imageUrl                String?
  totalQuantity           Int
  remainingQuantity       Int
  rankPosition            Int
  threadId                String?
  threadChannelId         String?
  warned3d                Boolean                  @default(false)
  warned4d                Boolean                  @default(false)
  updateProofImageUrl     String?
  updateProofNote         String?
  updateProofStatus       ItemRequestUpdateStatus?
  updateProofSubmittedAt  DateTime?
  updateProofReviewedAt   DateTime?
  updateProofReviewedById String?
  lastReminderStage       String?
  lastReminderAt          DateTime?
  legacyCreatedAt         DateTime?
  legacyUpdatedAt         DateTime?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  itemCatalog             ItemCatalog?             @relation(fields: [itemCatalogId], references: [id], onDelete: SetNull)
  player                  Player?                  @relation(fields: [playerId], references: [id], onDelete: SetNull)

  @@index([itemCatalogId])
  @@index([playerId])
  @@index([discordId])
  @@index([itemName])
  @@index([rankPosition])
  @@index([threadId])
  @@index([lastReminderStage])
  @@index([updateProofStatus])
  @@index([updateProofSubmittedAt])
}

model DropHistory {
  id                  String             @id @default(uuid())
  legacyId            Int?               @unique
  itemCatalogId       String?
  auctionId           String?            @unique
  itemInterestEntryId String?            @unique
  playerId            String?
  discordId           String?
  nicknameIngame      String?
  itemName            String?
  threadId            String?
  staffDiscordId      String?
  proofImageUrl       String?
  deliveredAt         DateTime?
  createdAt           DateTime           @default(now())
  itemCatalog         ItemCatalog?       @relation(fields: [itemCatalogId], references: [id], onDelete: SetNull)
  auction             Auction?           @relation(fields: [auctionId], references: [id], onDelete: SetNull)
  itemInterestEntry   ItemInterestEntry? @relation(fields: [itemInterestEntryId], references: [id], onDelete: SetNull)
  player              Player?            @relation(fields: [playerId], references: [id], onDelete: SetNull)

  @@index([itemCatalogId])
  @@index([playerId])
  @@index([itemInterestEntryId])
  @@index([discordId])
  @@index([itemName])
  @@index([threadId])
  @@index([deliveredAt])
}

model ItemInterestPost {
  id                      String              @id @default(uuid())
  itemCatalogId           String
  mode                    String              @default("PvE")
  title                   String
  criteriaPt              String
  criteriaEn              String
  status                  ItemInterestStatus  @default(OPEN)
  votingRound             Int                 @default(1)
  votingCandidateEntryIds Json                @default("[]")
  selectedEntryId         String?
  deliveryEnabledAt       DateTime?
  closesAt                DateTime
  closedAt                DateTime?
  proofImageUrl           String?
  createdById             String
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt
  itemCatalog             ItemCatalog         @relation(fields: [itemCatalogId], references: [id], onDelete: Cascade)
  createdBy               User                @relation("ItemInterestPostCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  entries                 ItemInterestEntry[]
  votes                   ItemInterestVote[]
  views                   ItemInterestView[]

  @@index([itemCatalogId])
  @@index([status])
  @@index([selectedEntryId])
  @@index([closesAt])
  @@index([createdById])
}

model ItemInterestView {
  id        String           @id @default(uuid())
  postId    String
  playerId  String
  seenAt    DateTime         @default(now())
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  post      ItemInterestPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  player    Player           @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([postId, playerId])
  @@index([playerId, seenAt])
  @@index([postId])
}

model ItemInterestEntry {
  id                 String             @id @default(uuid())
  postId             String
  playerId           String
  note               String?
  imageUrl           String?
  isTransmuteRequest Boolean            @default(false)
  createdAt          DateTime           @default(now())
  post               ItemInterestPost   @relation(fields: [postId], references: [id], onDelete: Cascade)
  player             Player             @relation(fields: [playerId], references: [id], onDelete: Cascade)
  dropHistory        DropHistory?
  votes              ItemInterestVote[]

  @@unique([postId, playerId])
  @@index([playerId])
  @@index([isTransmuteRequest])
  @@index([playerId, isTransmuteRequest])
}

model PlayerWishlistItem {
  id            String           @id @default(uuid())
  playerId      String
  itemCatalogId String
  priority      WishlistPriority @default(MEDIUM)
  status        WishlistStatus   @default(ACTIVE)
  reason        String
  build         String?
  note          String?
  proofImageUrl String?
  fulfilledById String?
  fulfilledAt   DateTime?
  fulfilledNote String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  player        Player           @relation(fields: [playerId], references: [id], onDelete: Cascade)
  itemCatalog   ItemCatalog      @relation(fields: [itemCatalogId], references: [id], onDelete: Cascade)

  @@index([playerId, status, priority])
  @@index([itemCatalogId, status, priority])
  @@index([status, updatedAt])
  @@index([fulfilledById])
}

model ItemInterestVote {
  id        String            @id @default(uuid())
  postId    String
  entryId   String
  voterId   String
  round     Int               @default(1)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  post      ItemInterestPost  @relation(fields: [postId], references: [id], onDelete: Cascade)
  entry     ItemInterestEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  voter     User              @relation("ItemInterestVoteVoter", fields: [voterId], references: [id], onDelete: Cascade)

  @@unique([postId, voterId, round])
  @@index([postId, round])
  @@index([entryId])
  @@index([voterId])
}

model CodexRequest {
  id               String             @id @default(uuid())
  playerId         String
  imageUrl         String
  note             String?
  status           CodexRequestStatus @default(PENDING)
  proofImageUrl    String?
  sentById         String?
  sentAt           DateTime?
  confirmedAt      DateTime?
  retryRequestedAt DateTime?
  queuedAt         DateTime           @default(now())
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  player           Player             @relation(fields: [playerId], references: [id], onDelete: Cascade)
  sentBy           User?              @relation("CodexRequestSentBy", fields: [sentById], references: [id], onDelete: SetNull)

  @@index([playerId])
  @@index([status])
  @@index([queuedAt])
  @@index([sentById])
  @@index([createdAt])
}

model DaoshiCashReceipt {
  id            String              @id @default(uuid())
  playerId      String
  proofImageUrl String?
  purchaseCents Int
  approvedCents Int?
  purchaseDate  DateTime
  couponCode    String              @default("AACD")
  status        DaoshiReceiptStatus @default(PENDING)
  playerNote    String?
  reviewNote    String?
  reviewedById  String?
  reviewedAt    DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  player        Player              @relation(fields: [playerId], references: [id], onDelete: Cascade)
  reviewedBy    User?               @relation("DaoshiReceiptReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([playerId, purchaseDate])
  @@index([status])
  @@index([purchaseDate])
  @@index([reviewedById])
}

model DaoshiRaffle {
  id             String   @id @default(uuid())
  month          String
  prizeUsdCents  Int      @default(5000)
  totalCents     Int
  totalCoupons   Int
  winnerPlayerId String?
  winnerCoupon   Int?
  entries        Json
  executedById   String
  executedAt     DateTime @default(now())
  createdAt      DateTime @default(now())
  winnerPlayer   Player?  @relation(fields: [winnerPlayerId], references: [id], onDelete: SetNull)
  executedBy     User     @relation("DaoshiRaffleExecutedBy", fields: [executedById], references: [id], onDelete: Restrict)

  @@unique([month])
  @@index([winnerPlayerId])
  @@index([executedById])
  @@index([executedAt])
}

model Announcement {
  id             String             @id @default(uuid())
  type           String
  title          String
  description    String?
  channelId      String
  mentionRoleId  String?
  eventTime      DateTime
  timezone       String             @default("America/Sao_Paulo")
  status         AnnouncementStatus @default(ACTIVE)
  warned4h       Boolean            @default(false)
  warned1h       Boolean            @default(false)
  warned30m      Boolean            @default(false)
  warnedNow      Boolean            @default(false)
  warnedDailyDay Int?
  createdById    String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  createdBy      User?              @relation("AnnouncementCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([eventTime])
  @@index([channelId])
  @@index([createdById])
}

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String?
  action     String
  targetType String
  targetId   String?
  metadata   Json?
  createdAt  DateTime @default(now())
  actor      User?    @relation("AuditLogActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([action])
  @@index([targetType, targetId])
  @@index([createdAt])
}
